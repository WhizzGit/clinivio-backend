{
  "name": "mediflow-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm exec prisma generate --schema=libs/database/prisma/schema.prisma && turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm exec prisma generate --schema=libs/database/prisma/schema.prisma",
    "db:push": "pnpm exec prisma db push --schema=libs/database/prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate deploy --schema=libs/database/prisma/schema.prisma",
    "db:studio": "pnpm exec prisma studio --schema=libs/database/prisma/schema.prisma",
    "db:seed": "node libs/database/prisma/seed.js",
    "docker:dev": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "msgpackr-extract",
      "prisma",
      "unrs-resolver"
    ]
  },
  "dependencies": {
    "@nestjs/throttler": "^6.5.0",
    "helmet": "^8.1.0",
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  }
}
