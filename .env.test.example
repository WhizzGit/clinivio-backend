# ─────────────────────────────────────────────────────────────────────────────
# .env.test — test environment configuration
#
# HOW TO SET UP A NEON TEST BRANCH:
#   1. Go to https://console.neon.tech → your project → Branches
#   2. Click "Create Branch" → name it "test" → base on main branch
#   3. Copy the connection string (pooler URL) for the test branch
#   4. Paste it as DATABASE_URL_TEST below and in GitHub Secrets
#
# For local integration testing:
#   cp .env.test.example .env.test
#   Fill in DATABASE_URL_TEST with your Neon test branch URL
#   Run: pnpm --filter @mediflow/api test:e2e
# ─────────────────────────────────────────────────────────────────────────────

# Neon test branch — isolated DB, reset between test runs as needed
DATABASE_URL_TEST=postgresql://user:password@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT (can use the same keys as dev for testing)
# JWT_SECRET=test-jwt-secret-change-me
JWT_REFRESH_SECRET=test-jwt-refresh-secret-change-me
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Redis — use a local Redis or Upstash free tier for test
REDIS_URL=redis://localhost:6379

# A real tenant slug that exists in your Neon test branch DB.
# Create one seed tenant before running integration tests.
TEST_TENANT_SLUG=test-hospital

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Actions secrets to configure (Settings → Secrets → Actions):
#
#   DATABASE_URL_TEST      — Neon test branch connection string (above)
#   JWT_SECRET             — same value as production (or a test value)
#   JWT_REFRESH_SECRET     — same value as production (or a test value)
#   REDIS_URL_TEST         — Redis URL for test environment
#   RENDER_DEPLOY_HOOK_URL — From Render dashboard → clinivio-api → Settings → Deploy Hook
#   VERCEL_DEPLOY_HOOK_URL — From Vercel dashboard → Project → Settings → Deploy Hooks
#
# GitHub Actions variables to configure (Settings → Variables → Actions):
#
#   INTEGRATION_TESTS_ENABLED  — set to "true" once the test DB is seeded
#   E2E_ENABLED                — set to "true" once staging frontend is deployed
#   API_HEALTH_URL             — e.g. https://clinivio-api.onrender.com
#   TEST_TENANT_SLUG           — slug of the seed tenant in the test DB
#   STAGING_PATIENT_PORTAL_URL — e.g. https://patient-staging.clinivio.com
#   NEXT_PUBLIC_API_URL        — production or staging API URL
# ─────────────────────────────────────────────────────────────────────────────
