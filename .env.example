# ─── Clinivio Backend — Unified API (.env.example) ─────────────────────────────
# Copy to .env (local) or .env.local (overrides). Never commit real secrets.
# Port
PORT=3000
NODE_ENV=development

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Runtime app: use POOLER endpoint (ep-xxxx-pooler.c-8.us-east-1.aws.neon.tech)
# Migrations:  use DIRECT endpoint (ep-xxxx.c-8.us-east-1.aws.neon.tech)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local dev: localhost:6379 (docker-compose)
# Render:    automatically injected via REDIS_URL from the managed Redis service
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://...   ← Render sets this automatically

# ─── Kafka (Upstash) ──────────────────────────────────────────────────────────
# Local dev: localhost:9092 (docker-compose)
# Production: get from https://console.upstash.com → Kafka → your cluster → Details
# Format: your-cluster-xxxx.upstash.io:9092
# The app starts fine without Kafka; events are silently dropped.
KAFKA_BROKERS=localhost:9092
KAFKA_SASL_USERNAME=           # Upstash: your cluster username
KAFKA_SASL_PASSWORD=           # Upstash: your cluster password
KAFKA_SSL=false                # Set to true for Upstash
KAFKA_CLIENT_ID=clinivio-api
KAFKA_GROUP_ID=clinivio-api-group

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_generate_a_random_64_char_hex
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=change_me_generate_another_random_64_char_hex
JWT_REFRESH_EXPIRES_IN=7d

# ─── WhatsApp Meta Cloud API ──────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_app_secret

# ─── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET=mediflow-documents

# ─── MSG91 (SMS fallback) ─────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_key
MSG91_SENDER_ID=MEDFLW

# ─── Rate limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=120

# ─── GST rates ────────────────────────────────────────────────────────────────
GST_CGST_RATE=0.09
GST_SGST_RATE=0.09
GST_IGST_RATE=0.18

# ─── App ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
