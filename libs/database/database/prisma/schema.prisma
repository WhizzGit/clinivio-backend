generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
  PHARMACIST
  LAB_TECHNICIAN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Language {
  EN
  HI
  TA
  TE
  KN
  BN
}

enum VisitType {
  OPD
  IPD
}

enum AppointmentType {
  IN_PERSON
  VIDEO
  FOLLOW_UP
}

// Full lifecycle: REGISTERED (receptionist entry) → PENDING_PAYMENT → CONFIRMED
// → CHECKED_IN → IN_PROGRESS → COMPLETED → SENT_TO_PHARMACY
enum AppointmentStatus {
  REGISTERED
  PENDING_PAYMENT
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  SENT_TO_PHARMACY
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum InvoiceType {
  CONSULTATION
  PHARMACY
  PROCEDURE
  LAB
  PACKAGE
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PRINT
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum SubscriptionTier {
  BASIC
  STANDARD
  PREMIUM
  ENTERPRISE
}

enum PharmacyOrderStatus {
  PENDING
  DISPENSING
  DISPENSED
  RETURNED
}

enum RoomType {
  GENERAL_WARD
  SEMI_PRIVATE
  PRIVATE
  ICU
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  UNDER_MAINTENANCE
}

enum IPDAdmissionStatus {
  ADMITTED
  UNDER_TREATMENT
  READY_FOR_DISCHARGE
  DISCHARGED
}

enum LabOrderStatus {
  PENDING
  SAMPLE_COLLECTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LabResultFlag {
  NORMAL
  ABNORMAL
  CRITICAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id                    String           @id @default(uuid())
  name                  String
  address               String?
  city                  String?
  state                 String?
  stateCode             String?          @map("state_code")
  pincode               String?
  gstin                 String?
  drugLicenseNo         String?          @map("drug_license_no")
  abhaHipId             String?          @map("abha_hip_id")
  whatsappPhoneNumberId String?          @map("whatsapp_phone_number_id")
  wabaId                String?          @map("waba_id")
  subscriptionTier      SubscriptionTier @default(BASIC) @map("subscription_tier")
  isActive              Boolean          @default(true) @map("is_active")
  // Hospital profile fields for printing (prescriptions, receipts, certificates)
  phone                 String?
  email                 String?
  website               String?
  logoUrl               String?          @map("logo_url")
  registrationNo        String?          @map("registration_no")
  tagline               String?
  printHeader           String?          @map("print_header")
  // Pharmacy-specific billing details
  pharmacyName          String?          @map("pharmacy_name")
  // Portal URL assigned by Super Admin
  portalUrl             String?          @map("portal_url")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  users               User[]
  patients            Patient[]
  patientFamilies     PatientFamily[]
  doctorProfiles      DoctorProfile[]
  departments         Department[]
  slots               DoctorSlot[]
  appointments        Appointment[]
  consultations       Consultation[]
  prescriptions       Prescription[]
  followUps           FollowUp[]
  invoices            Invoice[]
  pharmacyOrders      PharmacyOrder[]
  notificationLogs    NotificationLog[]
  pharmacyInventories PharmacyInventory[]
  rooms               Room[]
  beds                Bed[]
  ipdAdmissions       IPDAdmission[]
  ipdVitalSnapshots   IPDVitalSnapshot[]
  ipdTreatments       IPDTreatment[]
  ipdProcedures       IPDProcedure[]
  dischargeAdvices    DischargeAdvice[]
  dischargeSummaries  DischargeSummary[]
  labTests            LabTest[]
  labOrders           LabOrder[]

  @@map("tenants")
}

model PharmacyInventory {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  name          String
  genericName   String?   @map("generic_name")
  category      String?
  unit          String    @default("Tablet")
  stockQty      Int       @default(0) @map("stock_qty")
  reorderLevel  Int       @default(10) @map("reorder_level")
  batchNo       String?   @map("batch_no")
  expiryDate    DateTime? @map("expiry_date") @db.Date
  mrp           Decimal   @default(0) @map("mrp") @db.Decimal(10, 2)
  sellingPrice  Decimal   @default(0) @map("selling_price") @db.Decimal(10, 2)
  manufacturer  String?
  hsn           String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("pharmacy_inventory")
}

model User {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  email        String
  phone        String?
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  role         Role
  isActive     Boolean   @default(true) @map("is_active")
  mfaEnabled   Boolean   @default(false) @map("mfa_enabled")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctorProfile       DoctorProfile?
  appointments        Appointment[]      @relation("DoctorAppointments")
  consultations       Consultation[]     @relation("DoctorConsultations")
  ipdAdmissions       IPDAdmission[]     @relation("AttendingDoctor")
  ipdVitalSnapshots   IPDVitalSnapshot[] @relation("VitalRecorder")
  ipdTreatments       IPDTreatment[]     @relation("TreatmentOrderer")
  ipdProcedures       IPDProcedure[]     @relation("ProcedurePerformer")
  dischargeAdvices    DischargeAdvice[]  @relation("DischargeAdviceCreator")
  dischargeSummaries  DischargeSummary[] @relation("DischargeSummaryGenerator")
  labOrdersOrdered    LabOrder[]         @relation("LabOrderDoctor")
  labOrdersAssigned   LabOrder[]         @relation("LabOrderTechnician")

  @@unique([tenantId, email], name: "tenant_user_email_unique")
  @@map("users")
}

// Admin-configurable departments/specialties per tenant
model Department {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  description String?
  icon        String?
  color       String?  @default("#3B82F6")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctors      DoctorProfile[]
  appointments Appointment[]

  @@unique([tenantId, code], name: "tenant_department_code_unique")
  @@map("departments")
}

model DoctorProfile {
  id                   String     @id @default(uuid())
  userId               String     @unique @map("user_id")
  tenantId             String     @map("tenant_id")
  departmentId         String?    @map("department_id")
  registrationNo       String?    @map("registration_no")
  specialty            String?
  subSpecialty         String?    @map("sub_specialty")
  qualification        String?
  experienceYears      Int?       @map("experience_years")
  consultationFee      Decimal?   @map("consultation_fee") @db.Decimal(10, 2)
  languages            Language[] @default([EN])
  availabilitySchedule Json?      @map("availability_schedule")
  isAcceptingPatients  Boolean    @default(true) @map("is_accepting_patients")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  slots      DoctorSlot[]

  @@map("doctor_profiles")
}

// Groups multiple patients sharing one WhatsApp number (family/guardian)
model PatientFamily {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  whatsappPhone    String   @map("whatsapp_phone")
  primaryPatientId String?  @map("primary_patient_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patients Patient[]

  @@unique([tenantId, whatsappPhone], name: "tenant_family_whatsapp_unique")
  @@map("patient_families")
}

model Patient {
  id                    String    @id @default(uuid())
  tenantId              String    @map("tenant_id")
  familyId              String?   @map("family_id")
  uhid                  String
  firstName             String    @map("first_name")
  lastName              String?   @map("last_name")
  phone                 String
  whatsappPhone         String?   @map("whatsapp_phone")
  hasWhatsapp           Boolean   @default(true) @map("has_whatsapp")
  email                 String?
  dob                   DateTime? @db.Date
  gender                Gender?
  bloodGroup            String?   @map("blood_group")
  abhaId                String?   @map("abha_id")
  abhaAddress           String?   @map("abha_address")
  preferredLanguage     Language  @default(EN) @map("preferred_language")
  emergencyContactName  String?   @map("emergency_contact_name")
  emergencyContactPhone String?   @map("emergency_contact_phone")
  address               String?
  consentGivenAt        DateTime? @map("consent_given_at")
  consentVersion        String?   @map("consent_version")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  family           PatientFamily?    @relation(fields: [familyId], references: [id], onDelete: SetNull)
  appointments     Appointment[]
  consultations    Consultation[]
  invoices         Invoice[]
  pharmacyOrders   PharmacyOrder[]
  notificationLogs NotificationLog[]
  followUps        FollowUp[]
  ipdAdmissions    IPDAdmission[]
  labOrders        LabOrder[]

  @@unique([tenantId, uhid], name: "tenant_patient_uhid_unique")
  @@index([tenantId, phone])
  @@index([tenantId, familyId])
  @@map("patients")
}

model DoctorSlot {
  id              String    @id @default(uuid())
  tenantId        String    @map("tenant_id")
  doctorId        String    @map("doctor_id")
  slotDate        DateTime  @map("slot_date") @db.Date
  startTime       String    @map("start_time")
  endTime         String    @map("end_time")
  durationMinutes Int       @default(30) @map("duration_minutes")
  maxPatients     Int       @default(1) @map("max_patients")
  bookedCount     Int       @default(0) @map("booked_count")
  isBlocked       Boolean   @default(false) @map("is_blocked")
  blockReason     String?   @map("block_reason")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([tenantId, doctorId, slotDate, startTime], name: "tenant_doctor_slot_unique")
  @@map("doctor_slots")
}

model Appointment {
  id                    String            @id @default(uuid())
  tenantId              String            @map("tenant_id")
  patientId             String            @map("patient_id")
  doctorId              String            @map("doctor_id")
  slotId                String?           @map("slot_id")
  departmentId          String?           @map("department_id")
  visitType             VisitType         @default(OPD) @map("visit_type")
  appointmentType       AppointmentType   @default(IN_PERSON) @map("appointment_type")
  status                AppointmentStatus @default(REGISTERED)
  chiefComplaint        String?           @map("chief_complaint")
  referredBy            String?           @map("referred_by")
  opinionObtainedBy     String?           @map("opinion_obtained_by")
  tokenNumber           Int?              @map("token_number")
  paymentStatus         PaymentStatus     @default(PENDING) @map("payment_status")
  paymentAmount         Decimal?          @map("payment_amount") @db.Decimal(10, 2)
  razorpayOrderId       String?           @map("razorpay_order_id")
  razorpayPaymentId     String?           @map("razorpay_payment_id")
  registeredAt          DateTime          @default(now()) @map("registered_at")
  scheduledAt           DateTime?         @map("scheduled_at")
  confirmedAt           DateTime?         @map("confirmed_at")
  checkedInAt           DateTime?         @map("checked_in_at")
  completedAt           DateTime?         @map("completed_at")
  pharmacySentAt        DateTime?         @map("pharmacy_sent_at")
  cancelledAt           DateTime?         @map("cancelled_at")
  cancellationReason    String?           @map("cancellation_reason")
  confirmation24hSentAt DateTime?         @map("confirmation_24h_sent_at")
  reminder1hSentAt      DateTime?         @map("reminder_1h_sent_at")
  notes                 String?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor       User          @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Restrict)
  slot         DoctorSlot?   @relation(fields: [slotId], references: [id], onDelete: SetNull)
  department   Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  consultation  Consultation?
  invoices      Invoice[]
  pharmacyOrder PharmacyOrder?
  ipdAdmission  IPDAdmission?
  labOrders     LabOrder[]

  @@index([tenantId, status])
  @@index([tenantId, doctorId, status])
  @@index([tenantId, departmentId, status])
  @@map("appointments")
}

model Consultation {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  appointmentId String    @unique @map("appointment_id")
  doctorId      String    @map("doctor_id")
  patientId     String    @map("patient_id")

  // Vitals
  bpSystolic    Int?      @map("bp_systolic")
  bpDiastolic   Int?      @map("bp_diastolic")
  pulseRate     Int?      @map("pulse_rate")
  temperature   Decimal?  @db.Decimal(4, 1)
  weightKg      Decimal?  @map("weight_kg") @db.Decimal(5, 2)
  heightCm      Decimal?  @map("height_cm") @db.Decimal(5, 2)
  bmi           Decimal?  @db.Decimal(4, 1)
  spo2          Int?
  rbsMgDl       Decimal?  @map("rbs_mg_dl") @db.Decimal(5, 1)
  respiratoryRate Int?    @map("respiratory_rate")

  // Clinical
  observations  String?
  diagnosis     String?
  icdCodes      String[]  @default([]) @map("icd_codes")
  doctorNotes   String?   @map("doctor_notes")

  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  doctor        User           @relation("DoctorConsultations", fields: [doctorId], references: [id], onDelete: Restrict)
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescriptions Prescription[]
  followUps     FollowUp[]

  @@map("consultations")
}

model Prescription {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  consultationId String   @map("consultation_id")
  patientId      String   @map("patient_id")
  doctorId       String   @map("doctor_id")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consultation  Consultation       @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  items         PrescriptionItem[]
  pharmacyOrder PharmacyOrder?

  @@map("prescriptions")
}

model PrescriptionItem {
  id             String  @id @default(uuid())
  prescriptionId String  @map("prescription_id")
  medicineName   String  @map("medicine_name")
  genericName    String? @map("generic_name")
  dosage         String
  frequency      String
  duration       String
  instructions   String?
  quantity       Int     @default(1)
  isSubstitutable Boolean @default(true) @map("is_substitutable")

  prescription Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@map("prescription_items")
}

model FollowUp {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  consultationId String    @map("consultation_id")
  patientId      String    @map("patient_id")
  doctorId       String    @map("doctor_id")
  followUpDate   DateTime  @map("follow_up_date") @db.Date
  notes          String?
  reminderSentAt DateTime? @map("reminder_sent_at")
  isCompleted    Boolean   @default(false) @map("is_completed")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consultation Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("follow_ups")
}

model PharmacyOrder {
  id             String              @id @default(uuid())
  tenantId       String              @map("tenant_id")
  appointmentId  String              @unique @map("appointment_id")
  patientId      String              @map("patient_id")
  prescriptionId String?             @unique @map("prescription_id")
  status         PharmacyOrderStatus @default(PENDING)
  dispenserNotes String?             @map("dispenser_notes")
  dispensedAt    DateTime?           @map("dispensed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment  Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient      Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prescription Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)

  @@map("pharmacy_orders")
}

model Invoice {
  id               String        @id @default(uuid())
  tenantId         String        @map("tenant_id")
  patientId        String        @map("patient_id")
  appointmentId    String?       @map("appointment_id")
  ipdAdmissionId   String?       @map("ipd_admission_id")
  invoiceNumber    String        @map("invoice_number")
  invoiceDate      DateTime      @default(now()) @map("invoice_date") @db.Date
  invoiceType      InvoiceType   @map("invoice_type")
  lineItems        Json          @map("line_items")
  subtotal         Decimal       @map("subtotal") @db.Decimal(10, 2)
  discountAmount   Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  taxableAmount    Decimal       @default(0) @map("taxable_amount") @db.Decimal(10, 2)
  cgstAmount       Decimal       @default(0) @map("cgst_amount") @db.Decimal(10, 2)
  sgstAmount       Decimal       @default(0) @map("sgst_amount") @db.Decimal(10, 2)
  igstAmount       Decimal       @default(0) @map("igst_amount") @db.Decimal(10, 2)
  totalAmount      Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentStatus    PaymentStatus @default(PENDING) @map("payment_status")
  paymentMethod    String?       @map("payment_method")
  razorpayOrderId  String?       @map("razorpay_order_id")
  razorpayPaymentId String?      @map("razorpay_payment_id")
  paidAt           DateTime?     @map("paid_at")
  printCopyUrl     String?       @map("print_copy_url")
  irn              String?
  pdfS3Key         String?       @map("pdf_s3_key")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient       Patient       @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  ipdAdmission  IPDAdmission? @relation(fields: [ipdAdmissionId], references: [id], onDelete: SetNull)

  @@map("invoices")
}

model NotificationLog {

  id               String              @id @default(uuid())
  tenantId         String              @map("tenant_id")
  patientId        String              @map("patient_id")
  channel          NotificationChannel
  notificationType String              @map("notification_type")
  templateId       String?             @map("template_id")
  payload          Json
  status           NotificationStatus  @default(QUEUED)
  wamid            String?
  sentAt           DateTime?           @map("sent_at")
  deliveredAt      DateTime?           @map("delivered_at")
  readAt           DateTime?           @map("read_at")
  failureReason    String?             @map("failure_reason")
  createdAt        DateTime            @default(now()) @map("created_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@map("notification_logs")
}

// ─── IPD Models ───────────────────────────────────────────────────────────────

// Admin-configured rooms (ICU, Private, Semi-Private, General Ward)
model Room {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  roomType    RoomType @map("room_type")
  floor       String?
  totalBeds   Int      @map("total_beds")
  pricePerDay Decimal  @map("price_per_day") @db.Decimal(10, 2)
  amenities   Json?
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  beds       Bed[]
  admissions IPDAdmission[]

  @@index([tenantId])
  @@index([tenantId, roomType])
  @@map("rooms")
}

model Bed {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  roomId     String    @map("room_id")
  bedNumber  String    @map("bed_number")
  status     BedStatus @default(AVAILABLE)
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  room       Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  admissions IPDAdmission[]

  @@unique([roomId, bedNumber], name: "room_bed_unique")
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("beds")
}

model IPDAdmission {
  id                   String             @id @default(uuid())
  tenantId             String             @map("tenant_id")
  patientId            String             @map("patient_id")
  attendingDoctorId    String             @map("attending_doctor_id")
  appointmentId        String?            @unique @map("appointment_id")
  roomId               String             @map("room_id")
  bedId                String             @map("bed_id")
  admissionNumber      String             @map("admission_number")
  status               IPDAdmissionStatus @default(ADMITTED)
  admissionReason      String             @map("admission_reason")
  referredBy           String?            @map("referred_by")
  opinionObtainedBy    String?            @map("opinion_obtained_by")
  admittedAt           DateTime           @default(now()) @map("admitted_at")
  estimatedDischargeAt DateTime?          @map("estimated_discharge_at")
  dischargedAt         DateTime?          @map("discharged_at")
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient          Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  attendingDoctor  User               @relation("AttendingDoctor", fields: [attendingDoctorId], references: [id], onDelete: Restrict)
  appointment      Appointment?       @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  room             Room               @relation(fields: [roomId], references: [id], onDelete: Restrict)
  bed              Bed                @relation(fields: [bedId], references: [id], onDelete: Restrict)
  vitalSnapshots   IPDVitalSnapshot[]
  treatments       IPDTreatment[]
  procedures       IPDProcedure[]
  dischargeAdvice  DischargeAdvice?
  dischargeSummary DischargeSummary?
  invoices         Invoice[]

  @@unique([tenantId, admissionNumber], name: "tenant_admission_number_unique")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
  @@map("ipd_admissions")
}

// Repeated vitals during IPD stay (per shift/on demand) vs single OPD vitals
model IPDVitalSnapshot {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  admissionId     String   @map("admission_id")
  recordedById    String   @map("recorded_by_id")
  bpSystolic      Int?     @map("bp_systolic")
  bpDiastolic     Int?     @map("bp_diastolic")
  pulseRate       Int?     @map("pulse_rate")
  temperature     Decimal? @db.Decimal(4, 1)
  weightKg        Decimal? @map("weight_kg") @db.Decimal(5, 2)
  heightCm        Decimal? @map("height_cm") @db.Decimal(5, 2)
  bmi             Decimal? @db.Decimal(4, 1)
  spo2            Int?
  rbsMgDl         Decimal? @map("rbs_mg_dl") @db.Decimal(5, 1)
  respiratoryRate Int?     @map("respiratory_rate")
  notes           String?
  recordedAt      DateTime @default(now()) @map("recorded_at")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admission  IPDAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  recordedBy User         @relation("VitalRecorder", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([admissionId])
  @@index([tenantId, admissionId])
  @@map("ipd_vital_snapshots")
}

model IPDTreatment {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  admissionId   String   @map("admission_id")
  orderedById   String   @map("ordered_by_id")
  treatmentName String   @map("treatment_name")
  instructions  String?
  startedAt     DateTime @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")
  isActive      Boolean  @default(true) @map("is_active")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admission IPDAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  orderedBy User         @relation("TreatmentOrderer", fields: [orderedById], references: [id], onDelete: Restrict)

  @@index([admissionId])
  @@index([tenantId])
  @@map("ipd_treatments")
}

model IPDProcedure {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  admissionId   String   @map("admission_id")
  performedById String   @map("performed_by_id")
  procedureName String   @map("procedure_name")
  notes         String?
  photoUrls     String[] @default([]) @map("photo_urls")
  outcomes      String?
  complications String?
  performedAt   DateTime @default(now()) @map("performed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admission   IPDAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  performedBy User         @relation("ProcedurePerformer", fields: [performedById], references: [id], onDelete: Restrict)

  @@index([admissionId])
  @@index([tenantId])
  @@map("ipd_procedures")
}

// One per admission — discharge instructions given to patient
model DischargeAdvice {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  admissionId    String   @unique @map("admission_id")
  createdById    String   @map("created_by_id")
  medications    String?
  dietAdvice     String?  @map("diet_advice")
  activityAdvice String?  @map("activity_advice")
  woundCare      String?  @map("wound_care")
  otherAdvice    String?  @map("other_advice")
  followUpDate   DateTime? @map("follow_up_date") @db.Date
  followUpNotes  String?  @map("follow_up_notes")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admission IPDAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  createdBy User         @relation("DischargeAdviceCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("discharge_advice")
}

// One per admission — medical summary generated by doctor at discharge
model DischargeSummary {
  id                     String   @id @default(uuid())
  tenantId               String   @map("tenant_id")
  admissionId            String   @unique @map("admission_id")
  generatedById          String   @map("generated_by_id")
  finalDiagnosis         String   @map("final_diagnosis")
  presentingComplaints   String   @map("presenting_complaints")
  treatmentSummary       String   @map("treatment_summary")
  proceduresDone         String?  @map("procedures_done")
  investigationFindings  String?  @map("investigation_findings")
  conditionAtDischarge   String   @map("condition_at_discharge")
  pdfS3Key               String?  @map("pdf_s3_key")
  generatedAt            DateTime @default(now()) @map("generated_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  admission   IPDAdmission @relation(fields: [admissionId], references: [id], onDelete: Cascade)
  generatedBy User         @relation("DischargeSummaryGenerator", fields: [generatedById], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@map("discharge_summaries")
}

// ─── Lab Models ───────────────────────────────────────────────────────────────

// Admin-configured test catalog (CBC, LFT, RFT, etc.)
model LabTest {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  code        String
  category    String
  unit        String?
  normalRange String?  @map("normal_range")
  price       Decimal  @default(0) @db.Decimal(10, 2)
  turnaround  Int      @default(24) @map("turnaround_hours")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems LabOrderItem[]

  @@unique([tenantId, code], name: "tenant_lab_test_code_unique")
  @@index([tenantId])
  @@map("lab_tests")
}

// A single lab requisition — may contain multiple tests
model LabOrder {
  id             String         @id @default(uuid())
  tenantId       String         @map("tenant_id")
  orderNumber    String         @map("order_number")
  patientId      String         @map("patient_id")
  appointmentId  String?        @map("appointment_id")
  orderedById    String         @map("ordered_by_id")
  assignedToId   String?        @map("assigned_to_id")
  status         LabOrderStatus @default(PENDING)
  priority       String         @default("ROUTINE") @map("priority")
  clinicalNotes  String?        @map("clinical_notes")
  sampleType     String?        @map("sample_type")
  collectedAt    DateTime?      @map("collected_at")
  completedAt    DateTime?      @map("completed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient     Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  orderedBy   User           @relation("LabOrderDoctor", fields: [orderedById], references: [id], onDelete: Restrict)
  assignedTo  User?          @relation("LabOrderTechnician", fields: [assignedToId], references: [id], onDelete: SetNull)
  items       LabOrderItem[]

  @@unique([tenantId, orderNumber], name: "tenant_lab_order_number_unique")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
  @@map("lab_orders")
}

// Individual test result within an order
model LabOrderItem {
  id          String         @id @default(uuid())
  labOrderId  String         @map("lab_order_id")
  labTestId   String         @map("lab_test_id")
  result      String?
  unit        String?
  normalRange String?        @map("normal_range")
  flag        LabResultFlag?
  notes       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  labOrder LabOrder @relation(fields: [labOrderId], references: [id], onDelete: Cascade)
  labTest  LabTest  @relation(fields: [labTestId], references: [id], onDelete: Restrict)

  @@map("lab_order_items")
}
