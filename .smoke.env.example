# Smoke test credentials — copy this file to .smoke.env and fill in real values.
# .smoke.env is gitignored; this example file is committed.
#
# Run:  pnpm smoke

SMOKE_API_URL=http://localhost:3000
SMOKE_TENANT_SLUG=your-clinic-slug

SMOKE_ADMIN_EMAIL=admin@yourclinic.com
SMOKE_ADMIN_PASSWORD=

SMOKE_RECEPTIONIST_EMAIL=reception@yourclinic.com
SMOKE_RECEPTIONIST_PASSWORD=

SMOKE_NURSE_EMAIL=nurse@yourclinic.com
SMOKE_NURSE_PASSWORD=

SMOKE_DOCTOR_EMAIL=doctor@yourclinic.com
SMOKE_DOCTOR_PASSWORD=

SMOKE_LAB_EMAIL=lab@yourclinic.com
SMOKE_LAB_PASSWORD=

SMOKE_PHARMACIST_EMAIL=pharma@yourclinic.com
SMOKE_PHARMACIST_PASSWORD=
